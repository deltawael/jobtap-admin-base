// Prisma schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model SysTokens {
  id           String   @id @default(cuid())
  accessToken  String   @unique @map("access_token")
  refreshToken String   @unique @map("refresh_token")
  status       String
  userId       String   @map("user_id")
  username     String
  tenantId     String?  @map("tenant_id")
  loginTime    DateTime @default(now()) @map("login_time")
  ip           String
  port         Int?
  address      String
  userAgent    String   @map("user_agent")
  requestId    String   @map("request_id")
  type         String
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String   @map("created_by")

  @@index([tenantId])
  @@map("sys_tokens")
}

model SysUser {
  id          String    @id
  username    String    @unique
  password    String
  tenantId    String?   @map("tenant_id")
  actorType   ActorType @default(tenant_user) @map("actor_type")
  built_in    Boolean   @default(false)
  avatar      String?
  email       String?   @unique
  phoneNumber String?   @unique @map("phone_number")
  nickName    String    @map("nick_name")
  status      Status
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  @@index([tenantId])
  @@map("sys_user")
}

enum ActorType {
  system_admin
  tenant_admin
  tenant_user
}

enum Status {
  ENABLED
  DISABLED
  BANNED
}

model CasbinRule {
  id    Int     @id @default(autoincrement())
  ptype String
  v0    String?
  v1    String?
  v2    String?
  v3    String?
  v4    String?
  v5    String?

  @@map("casbin_rule")
}


model Tenant {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  status      Status
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  @@map("tenants")
}

model RoleTemplate {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  actorType   ActorType @map("actor_type")
  description String?
  status      Status
  builtIn     Boolean   @default(true) @map("built_in")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  @@map("role_templates")
}

model SysRole {
  id          String    @id
  code        String    @unique
  name        String
  tenantId    String?   @map("tenant_id")
  templateId  String?   @map("template_id")
  builtIn     Boolean   @default(false) @map("built_in")
  description String?
  pid         String    @default("0")
  status      Status
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  @@index([tenantId])
  @@index([templateId])
  @@map("sys_role")
}

enum CapabilityKind {
  action
  view
}

enum CapabilityBindingMode {
  ANY_OF
  ALL_OF
}

enum ScopeType {
  all
  self
  region
  department
  custom
}

enum DelegationStatus {
  active
  expired
  revoked
}

enum PolicyEffect {
  allow
  deny
}

model SysUserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  @@id([userId, roleId])
  @@map("sys_user_role")
}

model Capability {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  module      String
  kind        CapabilityKind
  builtIn     Boolean        @default(true) @map("built_in")
  description String?
  status      Status
  createdAt   DateTime       @default(now()) @map("created_at")
  createdBy   String         @map("created_by")
  updatedAt   DateTime?      @updatedAt @map("updated_at")
  updatedBy   String?        @map("updated_by")

  @@map("capabilities")
}

model RoleTemplateCapability {
  templateId   String @map("template_id")
  capabilityId String @map("capability_id")

  @@id([templateId, capabilityId])
  @@map("role_template_capabilities")
}

model RoleCapability {
  roleId       String @map("role_id")
  capabilityId String @map("capability_id")

  @@id([roleId, capabilityId])
  @@map("role_capabilities")
}

model ScopePolicy {
  id           String       @id @default(cuid())
  tenantId     String?      @map("tenant_id")
  roleId       String?      @map("role_id")
  capabilityId String       @map("capability_id")
  scopeType    ScopeType    @map("scope_type")
  scopeValue   String?      @map("scope_value")
  effect       PolicyEffect @default(allow)
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")
  createdBy    String       @map("created_by")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  updatedBy    String?      @map("updated_by")

  @@index([tenantId, roleId])
  @@map("scope_policies")
}

model UserScopeOverride {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  capabilityId String       @map("capability_id")
  scopeType    ScopeType    @map("scope_type")
  scopeValue   String?      @map("scope_value")
  effect       PolicyEffect @default(allow)
  startAt      DateTime?    @map("start_at")
  endAt        DateTime?    @map("end_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  createdBy    String       @map("created_by")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  updatedBy    String?      @map("updated_by")

  @@index([userId, capabilityId])
  @@map("user_scope_overrides")
}

model Delegation {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  fromUserId   String           @map("from_user_id")
  toUserId     String           @map("to_user_id")
  capabilityId String           @map("capability_id")
  scopeType    ScopeType        @map("scope_type")
  scopeValue   String?          @map("scope_value")
  status       DelegationStatus @default(active)
  startAt      DateTime         @map("start_at")
  endAt        DateTime         @map("end_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  createdBy    String           @map("created_by")
  updatedAt    DateTime?        @updatedAt @map("updated_at")
  updatedBy    String?          @map("updated_by")

  @@index([tenantId, toUserId, capabilityId])
  @@map("delegations")
}

model UserStaffBinding {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  userId    String    @unique @map("user_id")
  staffId   String    @map("staff_id")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @map("created_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")

  @@index([tenantId, staffId])
  @@map("user_staff_bindings")
}

model CapabilityUiBinding {
  id           String    @id @default(cuid())
  capabilityId String    @map("capability_id")
  resourceType String    @map("resource_type")
  resourceCode String    @map("resource_code")
  menuId       Int?      @map("menu_id")
  routeName    String?   @map("route_name")
  buttonCode   String?   @map("button_code")
  createdAt    DateTime  @default(now()) @map("created_at")
  createdBy    String    @map("created_by")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  updatedBy    String?   @map("updated_by")

  @@index([capabilityId, resourceType])
  @@map("capability_ui_bindings")
}

model CapabilityApiBinding {
  id           String                @id @default(cuid())
  capabilityId String                @map("capability_id")
  endpointId   String?               @map("endpoint_id")
  resource     String
  action       String
  bindingMode  CapabilityBindingMode @default(ANY_OF) @map("binding_mode")
  method       String?
  path         String?
  createdAt    DateTime              @default(now()) @map("created_at")
  createdBy    String                @map("created_by")
  updatedAt    DateTime?             @updatedAt @map("updated_at")
  updatedBy    String?               @map("updated_by")

  @@index([capabilityId, resource, action])
  @@map("capability_api_bindings")
}

model CapabilityViewBinding {
  id           String    @id @default(cuid())
  capabilityId String    @map("capability_id")
  resourceType String    @map("resource_type")
  viewKey      String    @map("view_key")
  createdAt    DateTime  @default(now()) @map("created_at")
  createdBy    String    @map("created_by")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  updatedBy    String?   @map("updated_by")

  @@index([capabilityId, resourceType])
  @@map("capability_view_bindings")
}

model SysEndpoint {
  id         String    @id
  path       String
  method     String
  action     String
  resource   String
  controller String
  summary    String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("sys_endpoint")
}

model SysOrganization {
  id          String    @id
  code        String    @unique
  name        String
  description String?
  pid         String    @default("0")
  status      Status
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by")

  @@map("sys_organization")
}

model SysLoginLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  username  String
  tenantId  String?  @map("tenant_id")
  loginTime DateTime @default(now()) @map("login_time")
  ip        String
  port      Int?
  address   String
  userAgent String   @map("user_agent")
  requestId String   @map("request_id")
  type      String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @map("created_by")

  @@index([tenantId])
  @@map("sys_login_log")
}

model SysOperationLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  username    String
  tenantId    String?  @map("tenant_id")
  moduleName  String   @map("module_name")
  description String
  requestId   String   @map("request_id")
  method      String
  url         String
  ip          String
  userAgent   String?  @map("user_agent")
  params      Json?    @map("params")
  body        Json?    @map("body")
  response    Json?    @map("response")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  duration    Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("sys_operation_log")
}

enum MenuType {
  directory
  menu
  button
}

model SysMenu {
  id        Int      @id @default(autoincrement())
  menuType  MenuType @map("menu_type")
  menuName  String   @map("menu_name") @db.VarChar(64)
  iconType  Int?     @default(1) @map("icon_type")
  icon      String?  @map("icon") @db.VarChar(64)
  routeName String   @unique @map("route_name") @db.VarChar(64)
  routePath String   @map("route_path") @db.VarChar(128)
  component String   @map("component") @db.VarChar(64)
  pathParam String?  @map("path_param") @db.VarChar(64)
  status    Status

  activeMenu String?  @map("active_menu") @db.VarChar(64)
  hideInMenu Boolean? @default(false) @map("hide_in_menu")
  pid        Int      @default(0)
  order      Int      @map("sequence")
  i18nKey    String?  @map("i18n_key") @db.VarChar(64)
  keepAlive  Boolean? @default(false) @map("keep_alive")
  constant   Boolean  @default(false)
  href       String?  @map("href") @db.VarChar(64)
  multiTab   Boolean? @default(false) @map("multi_tab")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @map("created_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by")

  @@map("sys_menu")
}


model AuditLog {
  id            String    @id @default(cuid())
  tenantId      String?   @map("tenant_id")
  actorUserId   String    @map("actor_user_id")
  actorUsername String    @map("actor_username")
  actorType     ActorType @map("actor_type")
  action        String
  resourceType  String    @map("resource_type")
  resourceId    String?   @map("resource_id")
  detail        Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([tenantId, resourceType, createdAt])
  @@map("audit_logs")
}

model SysAccessKey {
  id              String   @id @default(cuid())
  tenantId        String?  @map("tenant_id")
  AccessKeyID     String   @unique @map("access_key_id")
  AccessKeySecret String   @unique @map("access_key_secret")
  status          Status
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  createdBy       String   @map("created_by")

  @@index([tenantId])
  @@map("sys_access_key")
}
